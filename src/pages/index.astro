---
import CRMLayout from '../layouts/CRMLayout.astro';
import ObsidianNav from '../components/obsidian/ObsidianNav';
import ObsidianHero from '../components/obsidian/ObsidianHero';
import SocialProof from '../components/obsidian/SocialProof';
import PlatformSection from '../components/obsidian/PlatformSection';
import AnalyticsSection from '../components/obsidian/AnalyticsSection';
import CTASection from '../components/obsidian/CTASection';
import ObsidianFooter from '../components/obsidian/ObsidianFooter';
import CursorFollower from '../components/ui/CursorFollower';
---

<CRMLayout>
  <CursorFollower client:load />

  <!-- Navigation -->
  <ObsidianNav client:load />

  <main>
    <!-- Hero -->
    <ObsidianHero client:load />

    <!-- Social Proof logos strip -->
    <SocialProof client:load />

    <!-- Platform cards -->
    <PlatformSection client:load />

    <!-- Analytics split section -->
    <AnalyticsSection client:load />

    <!-- CTA -->
    <CTASection client:load />
  </main>

  <!-- Footer -->
  <ObsidianFooter />
</CRMLayout>
